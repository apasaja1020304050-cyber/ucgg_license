{
    "version": 2,
    "builds": [
        {
            "src": "api/license.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/license.py"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}
